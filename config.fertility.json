  "novelty_control": {
    "_comment": "Cross-run repeat suppression using SQLite. History file lives next to the config.",
    "history_path": "selection_history.db",
    "suppress_previously_emitted": true,
    "suppress_previously_seen": false,
    "allow_repeat_after_days": 90,
    "lookback_days": 14,
    "identity_priority": ["doi", "pmid", "url", "fingerprint"],
    "update_history_on_selection": true,
    "update_history_on_publish": false
  },

  "source_diversity": {
    "_comment": "Prevent a single journal from dominating the issue. Hard caps applied before final selection.",
    "max_main_stories_per_source": 1,
    "max_quick_hits_per_source": 2,
    "max_total_selected_per_source": 3,
    "min_distinct_sources_main": 2,
    "min_distinct_sources_total": 3,
    "allow_underfilled_issue_if_diversity_not_met": true,
    "source_penalty_after_threshold": 0.3
  },

  "evidence_thresholds": {
    "_comment": "Minimum pre-LLM evidence quality. Uses content-length heuristic before summariser runs.",
    "min_main_story_sufficiency": 0.55,
    "min_quick_hit_sufficiency": 0.20,
    "min_main_story_confidence": "low",
    "allow_abstract_only_main_story": true,
    "allow_abstract_only_quick_hit": true,
    "drop_if_no_findings_extracted": false,
    "downgrade_if_findings_missing": true
  },

  "freshness_rules": {
    "_comment": "Per-tier date requirements with explicit fallback freshness attribution.",
    "require_published_at_for_main_story": true,
    "require_published_at_for_quick_hit": false,
    "max_age_days_main_story": 21,
    "max_age_days_quick_hit": 30,
    "fallback_date_sources": ["freshness_date", "updated_date", "first_seen_at", "fetched_at"],
    "penalize_missing_date": true,
    "missing_date_penalty": 2.0
  },

  "article_type_rules": {
    "_comment": "Title-pattern classification takes priority. default_type=original_research so unclassified journal articles are treated as research.",
    "explicit_patterns": {},
    "default_type": "original_research",
    "demote_types_for_main_story": [
      "editorial", "letter", "correction", "erratum",
      "retraction", "commentary"
    ],
    "exclude_types": ["correction", "erratum", "retraction"],
    "review_type_labels": ["review", "systematic_review", "meta_analysis"]
  },

  "negative_scoring": {
    "_comment": "Score penalties subtracted from impact_score before selection.",
    "keywords": {},
    "phrases": [],
    "article_types": {
      "editorial":   -3.0,
      "letter":      -4.0,
      "correction":  -10.0,
      "erratum":     -10.0,
      "retraction":  -10.0,
      "commentary":  -2.0,
      "guideline":   -1.0
    },
    "missing_metadata_penalties": {
      "missing_published_date": -2.0,
      "missing_findings":       -3.0,
      "low_sufficiency":        -2.0
    }
  },

  "main_story_rules": {
    "_comment": "Hard eligibility gates. Prefer false negatives over false positives.",
    "min_reportability_score": 0.0,
    "min_impact_score": 3.0,
    "require_nontrivial_findings": true,
    "min_findings_length": 80,
    "require_distinct_angle_from_other_main_stories": false,
    "max_main_stories_same_source_family": 1,
    "require_evidence_above_quick_hit_floor": true,
    "eligible_article_types": [
      "original_research",
      "systematic_review",
      "meta_analysis",
      "rct",
      "cohort_study",
      "observational_study",
      "case_report",
      "guideline"
    ],
    "ineligible_article_types": [
      "editorial", "commentary", "letter",
      "correction", "erratum", "retraction"
    ],
    "disallow_if_findings_contain": [
      "Detailed findings were not available",
      "consult the primary source for methods and results",
      "not available in the retrieved source text",
      "The available text describes",
      "This appears to be"
    ]
  },

  "quick_hit_rules": {
    "_comment": "More permissive than main stories; still gates on minimum quality.",
    "min_evidence_sufficiency": 0.20,
    "allow_abstract_only": true,
    "require_title_and_url": true,
    "max_age_days": 30,
    "drop_if_explicitly_no_findings": false,
    "disallow_if_findings_contain": [],
    "ineligible_article_types": ["correction", "erratum", "retraction"]
  },

  "topic_assignment": {
    "_comment": "Controls primary/secondary topic assignment from topic_categories keywords.",
    "primary_topic_required": true,
    "max_topics_per_article": 3,
    "max_secondary_topics": 2,
    "topic_priority": [
      "male_factor",
      "genetics_genomics",
      "endometriosis",
      "pcos",
      "ovarian_reserve",
      "fertility_preservation",
      "art_ivf",
      "embryology",
      "implantation",
      "pregnancy_outcomes",
      "preconception_care",
      "natural_conception_ttc",
      "mental_health",
      "hormones_pharmacology",
      "complementary_integrative",
      "reproductive_endocrinology",
      "reviews"
    ],
    "min_keyword_hits_for_topic": 1,
    "allow_secondary_topics": true
  },

  "selection_diagnostics": {
    "_comment": "Per-item diagnostics emitted in the consolidated report.",
    "enabled": true
  }
}
